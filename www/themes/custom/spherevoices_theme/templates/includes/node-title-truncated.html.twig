{#
/**
 * @file
 * Titre affiché en liste : au-delà de 60 caractères, tronquer et ajouter "...".
 *
 * @var title_render
 *   Chaîne ou render array (souvent `label`).
 */
#}
{% set plain = title_render|render|striptags|trim %}
{% if plain|length > 60 %}
  {{ plain|slice(0, 60) ~ '...' }}
{% else %}
  {{ plain }}
{% endif %}
