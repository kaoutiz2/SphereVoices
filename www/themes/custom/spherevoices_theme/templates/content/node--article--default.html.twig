{#
/**
 * @file
 * Template pour les articles en mode default (page complète du nœud).
 * Même logique que node--article--full : bandeau vidéo/image + corps avec drupal-media remplacé.
 */
#}
<article{{ attributes.addClass('article-full') }}>

  {{ title_prefix }}
  {% if label %}
    <h1{{ title_attributes.addClass('article-full-title') }}>
      {{ label }}
    </h1>
  {% endif %}
  {{ title_suffix }}

  {% if display_submitted %}
    <footer class="article-full-meta">
      {{ author_picture }}
      <div{{ author_attributes }}>
        {% trans %}Submitted by {{ author_name }} on {{ date }}{% endtrans %}
        {{ metadata }}
      </div>
    </footer>
  {% endif %}

  <div{{ content_attributes.addClass('article-full-content') }}>
    {# Bandeau en haut : vidéo ou image #}
    {% if article_hero_video_uri is defined and article_hero_video_uri %}
      <div class="article-full-image">
        <video controls preload="metadata" style="width: 100%; height: auto; display: block;">
          <source src="{{ file_url(article_hero_video_uri) }}">
        </video>
      </div>
    {% elseif article_hero_image is defined and article_hero_image and article_hero_image.uri %}
      <div class="article-full-image">
        <img src="{{ file_url(article_hero_image.uri) }}" alt="{{ article_hero_image.alt|default('') }}" />
      </div>
    {% elseif content.field_media_thumbnail is defined and content.field_media_thumbnail|render|trim is not empty %}
      <div class="article-full-image">
        {{ content.field_media_thumbnail }}
      </div>
    {% elseif content.field_image is defined and content.field_image|render|trim is not empty %}
      <div class="article-full-image">
        {{ content.field_image }}
      </div>
    {% endif %}

    {# Corps : uniquement article_body_processed ; si div vidéo vide détectée, afficher un message #}
    <div class="article-body">
      {% if body_format_debug is defined %}
        <p class="body-format-debug" style="font-size:0.75rem;color:#666;margin-bottom:0.5rem;">Format du corps : <strong>{{ body_format_debug }}</strong></p>
      {% endif %}
      {% if article_body_processed is defined and article_body_processed %}
        {% set body_rendered = article_body_processed|render %}
        {% set msg = '<p class="media-video-missing">Vidéo : ré-enregistrez l’article après avoir ré-inséré la vidéo via le bouton « Média » dans le corps.</p>' %}
        {# Remplacer la div vidéo vide (plusieurs variantes) par le message #}
        {% set body_rendered = body_rendered|replace({
          '<div class="media-video-embed"></div>': msg,
          '<div class="media-video-embed"> </div>': msg,
          '<div class="media-video-embed">  </div>': msg,
          '<div class="media-video-embed">&nbsp;</div>': msg,
          '<div class="media-video-embed">\n</div>': msg,
          '<div class="media-video-embed">\n\n</div>': msg,
          '<div class="media-video-embed">\n \n</div>': msg,
        }) %}
        {{ body_rendered|raw }}
      {% endif %}
    </div>

    {# Autres champs #}
    {{ content|without('field_image', 'field_media_thumbnail', 'media_thumbnail', 'body') }}
  </div>

</article>
