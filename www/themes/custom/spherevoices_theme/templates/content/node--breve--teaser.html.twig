{#
/**
 * @file
 * Template pour l'affichage des brèves en mode teaser.
 */
#}
<article class="breve-item">
  <div class="breve-content">
    <h3 class="breve-title">
      <a href="{{ url }}" rel="bookmark">{% include '@spherevoices_theme/includes/node-title-truncated.html.twig' with { title_render: label } only %}</a>
    </h3>
    
    <div class="breve-meta">
      <span class="breve-date">{{ node.created.value|date('d/m/Y H:i') }}</span>
    </div>
  </div>
</article>



