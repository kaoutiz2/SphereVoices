{#
/**
 * @file
 * Template pour les articles en mode full.
 * Affiche l'image originale sans style Drupal.
 */
#}
<article{{ attributes.addClass('article-full') }}>

  {{ title_prefix }}
  {% if label %}
    <h1{{ title_attributes.addClass('article-full-title') }}>
      {{ label }}
    </h1>
  {% endif %}
  {{ title_suffix }}

  {% if display_submitted %}
    <footer class="article-full-meta">
      {{ author_picture }}
      <div{{ author_attributes }}>
        {% trans %}Submitted by {{ author_name }} on {{ date }}{% endtrans %}
        {{ metadata }}
      </div>
    </footer>
  {% endif %}

  <div{{ content_attributes.addClass('article-full-content') }}>
    {# Bandeau : field_cover_media (sv-video) puis miniature / image classique #}
    {% if article_cover_video_src is defined and article_cover_video_src %}
      <div class="article-full-image">
        <video controls preload="metadata" playsinline style="width: 100%; height: auto; display: block;">
          <source src="{{ article_cover_video_src }}" type="video/mp4">
        </video>
      </div>
    {% elseif article_cover_image is defined and article_cover_image.uri is defined and article_cover_image.uri %}
      <div class="article-full-image">
        <img src="{{ file_url(article_cover_image.uri) }}" alt="{{ article_cover_image.alt|default('') }}" />
      </div>
    {% elseif content.field_media_thumbnail is defined and content.field_media_thumbnail|render|trim is not empty %}
      <div class="article-full-image">
        {{ content.field_media_thumbnail }}
      </div>
    {% elseif content.field_image is defined and content.field_image|render|trim is not empty %}
      <div class="article-full-image">
        {{ content.field_image }}
      </div>
    {% endif %}

    {# Corps : segments = HTML + lecteur (balise <video> ici, URL fournie par spherevoices_core). #}
    <div class="article-body">
      {% if body_format_debug is defined %}
        <p class="body-format-debug" style="font-size:0.75rem;color:#666;margin-bottom:0.5rem;">Format du corps : <strong>{{ body_format_debug }}</strong></p>
      {% endif %}
      {% if article_body_segments is defined and article_body_segments|length > 0 %}
        {% for segment in article_body_segments %}
          {% if segment.kind == 'video_stream' and segment.src %}
            <div class="media-video-embed">
              <video class="media-video-embed__video" src="{{ segment.src }}" controls preload="metadata" playsinline></video>
            </div>
          {% elseif segment.kind == 'html' %}
            {{ segment.html }}
          {% endif %}
        {% endfor %}
      {% elseif article_body_final is defined %}
        {{ article_body_final }}
      {% elseif content.body %}
        {{ content.body }}
      {% endif %}
    </div>

    {# Autres champs (tags, tweet, etc.) — pas de commentaires / liens d’action #}
    {{ content|without('field_couverture', 'field_cover_media', 'field_image', 'field_media_thumbnail', 'media_thumbnail', 'body', 'comment', 'links') }}
  </div>

</article>



