{#
/**
 * @file
 * Template pour l'affichage d'un article en mode teaser (colonnes gauche/droite).
 */
#}
{% set miniature_label = '' %}
{% if node.hasField('field_teaser_bottom_label') and node.field_teaser_bottom_label.value is not empty %}
  {% set miniature_label = node.field_teaser_bottom_label.value %}
{% elseif node.hasField('field_label_miniature') and node.field_label_miniature.value is not empty %}
  {% set miniature_label = node.field_label_miniature.value %}
{% elseif node.hasField('field_field_teaser_bottom_label') and node.field_field_teaser_bottom_label.value is not empty %}
  {% set miniature_label = node.field_field_teaser_bottom_label.value %}
{% endif %}

{% set is_sponsored_article = node.hasField('field_sponsored') and node.field_sponsored.value %}

{% if (node.breaking_news_context or node.sticky.value) and not (force_standard_teaser|default(false)) %}
  {# Breaking News - Layout horizontal #}
  <article{{ attributes.addClass('article-breaking-news') }}>
    <a href="{{ url }}" class="article-breaking-news-link">
      <div class="article-breaking-news-image-wrapper">
        <div class="article-breaking-news-label">
          {% set breaking_label = 'BREAKING NEWS' %}
          {% if node.hasField('field_breaking_news_label') and node.field_breaking_news_label.value is not empty %}
            {% set breaking_label = node.field_breaking_news_label.value %}
          {% elseif node.hasField('field_field_breaking_news_label') and node.field_field_breaking_news_label.value is not empty %}
            {% set breaking_label = node.field_field_breaking_news_label.value %}
          {% endif %}
          <span class="breaking-news-badge">{{ breaking_label }}</span>
        </div>
        {% if article_cover_video_src is defined and article_cover_video_src %}
          <div class="article-breaking-news-image js-teaser-video-container">
            <video class="js-teaser-video" controls autoplay muted playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover; display: block;">
              <source src="{{ article_cover_video_src }}" type="video/mp4">
            </video>
          </div>
        {% elseif article_cover_image is defined and article_cover_image.uri is defined and article_cover_image.uri %}
          <div class="article-breaking-news-image">
            <img src="{{ file_url(article_cover_image.uri) }}" alt="{{ article_cover_image.alt|default('') }}" class="article-teaser-img-cover" />
          </div>
        {% elseif node.field_media_thumbnail is defined and node.field_media_thumbnail.entity %}
          {% set media = node.field_media_thumbnail.entity %}
          {% if media.field_media_video_file is defined and media.field_media_video_file.entity %}
            {% set video_file = media.field_media_video_file.entity %}
            {% set video_uri = video_file.uri.value %}
            <div class="article-breaking-news-image js-teaser-video-container">
              <video class="js-teaser-video" controls autoplay muted playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                <source src="{{ file_url(video_uri) }}">
              </video>
            </div>
          {% else %}
            {% if content.field_media_thumbnail is defined %}
              <div class="article-breaking-news-image">
                {{ content.field_media_thumbnail }}
              </div>
            {% endif %}
          {% endif %}
        {% elseif node.field_image.entity %}
          <div class="article-breaking-news-image">
            {% set image_file = node.field_image.entity %}
            {% set image_uri = image_file.uri.value %}
            <img src="{{ file_url(image_uri) }}" alt="{{ node.field_image.alt }}" class="article-teaser-img-cover" />
          </div>
        {% else %}
          <div class="article-breaking-news-image article-breaking-news-image-placeholder">
            <div class="placeholder-content">Image</div>
          </div>
        {% endif %}
        {% if is_sponsored_article %}
          <div class="article-teaser-bottom-label article-teaser-sponsored-label">{{ 'Article sponsorisé'|t }}</div>
        {% elseif miniature_label %}
          <div class="article-teaser-bottom-label">{{ miniature_label }}</div>
        {% endif %}
      </div>
      <div class="article-breaking-news-content">
        <h2 class="article-breaking-news-title">{{ label }}</h2>
        {% if content.field_summary|render %}
          <div class="article-breaking-news-summary">
            {{ content.field_summary }}
          </div>
        {% endif %}
      </div>
    </a>
  </article>
{% else %}
  {# Article normal - Layout vertical #}
  <article{{ attributes.addClass('article-teaser') }}>
    <a href="{{ url }}" class="article-teaser-link">
      <div class="article-teaser-image-wrapper">
        {% if article_cover_video_src is defined and article_cover_video_src %}
          <div class="article-teaser-image js-teaser-video-container">
            <video class="js-teaser-video" controls autoplay muted playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover; display: block;">
              <source src="{{ article_cover_video_src }}" type="video/mp4">
            </video>
          </div>
        {% elseif article_cover_image is defined and article_cover_image.uri is defined and article_cover_image.uri %}
          <div class="article-teaser-image">
            <img src="{{ file_url(article_cover_image.uri) }}" alt="{{ article_cover_image.alt|default('') }}" class="article-teaser-img-cover" />
          </div>
        {% elseif node.field_media_thumbnail is defined and node.field_media_thumbnail.entity %}
          {% set media = node.field_media_thumbnail.entity %}
          {% if media.field_media_video_file is defined and media.field_media_video_file.entity %}
            {% set video_file = media.field_media_video_file.entity %}
            {% set video_uri = video_file.uri.value %}
            <div class="article-teaser-image js-teaser-video-container">
              <video class="js-teaser-video" controls autoplay muted playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                <source src="{{ file_url(video_uri) }}">
              </video>
            </div>
          {% else %}
            {% if content.field_media_thumbnail is defined %}
              <div class="article-teaser-image">
                {{ content.field_media_thumbnail }}
              </div>
            {% endif %}
          {% endif %}
        {% elseif node.field_image.entity %}
          <div class="article-teaser-image">
            {% set image_file = node.field_image.entity %}
            {% set image_uri = image_file.uri.value %}
            <img src="{{ file_url(image_uri) }}" alt="{{ node.field_image.alt }}" class="article-teaser-img-cover" />
          </div>
        {% else %}
          <div class="article-teaser-image article-teaser-image-placeholder">
            <div class="placeholder-content">Image</div>
          </div>
        {% endif %}
        {% if is_sponsored_article %}
          <div class="article-teaser-bottom-label article-teaser-sponsored-label">{{ 'Article sponsorisé'|t }}</div>
        {% elseif miniature_label %}
          <div class="article-teaser-bottom-label">{{ miniature_label }}</div>
        {% endif %}
      </div>
      <div class="article-teaser-content">
        <h3 class="article-teaser-title">{{ label }}</h3>
        {% if content.field_summary|render %}
          <div class="article-teaser-summary">
            {{ content.field_summary }}
          </div>
        {% endif %}
      </div>
    </a>
  </article>
{% endif %}
