{#
/**
 * @file
 * Page liste des brèves (/breves) : en-tête / pied habituels, pas de bandeau ni colonnes latérales.
 */
#}
{# Bandeau header : spherevoices_core_page_top() (module) #}
<div class="page-wrapper page-wrapper--breves-list">
  <header class="site-header" role="banner">
    <div class="header-main">
      <div class="header-main-inner site-content-width">
        <div class="header-left-section" style="display: flex !important; flex-direction: row !important; align-items: center !important; flex-wrap: nowrap;">
        <div class="header-logo-nav-row">
          {% if page.header %}
            <div class="site-branding" style="flex: 0 0 100px !important; width: 100px !important; min-width: 100px !important;">
              {{ page.header }}
            </div>
          {% endif %}
          {% if page.navigation %}
            <nav class="main-navigation mobile-menu-hidden" role="navigation" aria-label="Main navigation">
              {{ page.navigation }}
            </nav>
          {% endif %}
          <a href="/search/node" class="header-search-icon" aria-label="{{ 'Rechercher'|t }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
              <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span class="menu-toggle-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
      </div>
      <div class="header-right-section">
        <div class="header-user-section">
          <div class="header-user-links">
            {% if page.header_user %}
              {{ page.header_user }}
            {% endif %}
          </div>
        </div>
      </div>
      </div>
    </div>
    <div class="header-subnav" role="navigation" aria-label="{{ 'Sous-navigation'|t }}">
      <div class="header-subnav-inner site-content-width">
        {{ page.header_subnav }}
      </div>
    </div>
  </header>

  {% if page.breadcrumb %}
    <div class="breadcrumb-wrapper">
      {{ page.breadcrumb }}
    </div>
  {% endif %}

  {% if page.highlighted %}
    <div class="highlighted">
      {{ page.highlighted }}
    </div>
  {% endif %}

  <main class="main-content site-content-width main-content--breves-simple" role="main">
    <div class="content-wrapper content-wrapper--breves-simple">
      {% if page_title %}
        <h1 class="page-title">{{ page_title }}</h1>
      {% endif %}
      {{ page.content }}
    </div>
  </main>

  {% include '@spherevoices_theme/layout/footer-site.html.twig' %}
</div>
