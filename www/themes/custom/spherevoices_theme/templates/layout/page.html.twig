{#
/**
 * @file
 * Template principal de page pour SphereVoices.
 *
 * Variables disponibles:
 * - page.header: Contenu de la région header
 * - page.header_top: Contenu de la région header top (breaking news)
 * - page.navigation: Menu de navigation
 * - page.header_subnav: Sous-barre sous le bandeau rouge
 * - page.content: Contenu principal
 * - page.footer: Footer
 */
#}
<div class="page-wrapper">
  <header class="site-header" role="banner">
    {% if page.header_top %}
      <div class="header-top">
        {{ page.header_top }}
      </div>
    {% endif %}
    <div class="header-main">
      <div class="header-main-inner site-content-width">
        <div class="header-left-section" style="display: flex !important; flex-direction: row !important; align-items: center !important; flex-wrap: nowrap;">
        <div class="header-logo-nav-row">
          {% if page.header %}
            <div class="site-branding" style="flex: 0 0 100px !important; width: 100px !important; min-width: 100px !important;">
              {{ page.header }}
            </div>
          {% endif %}
          {% if page.navigation %}
            <nav class="main-navigation mobile-menu-hidden" role="navigation" aria-label="Main navigation">
              {{ page.navigation }}
            </nav>
          {% endif %}
        </div>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span class="menu-toggle-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
      </div>
      <div class="header-right-section">
        <div class="header-search">
          <form action="/search" method="get" class="search-form-inline">
            <input type="search" name="keys" placeholder="Rechercher..." class="search-input-inline" />
            <button type="submit" class="search-button-inline" aria-label="Rechercher">
              <svg class="search-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
              </svg>
            </button>
          </form>
        </div>
        <div class="header-user-section">
          <div class="header-user-links">
            {% if page.header_user %}
              {{ page.header_user }}
            {% endif %}
          </div>
        </div>
      </div>
      </div>
    </div>
    <div class="header-subnav" role="navigation" aria-label="{{ 'Sous-navigation'|t }}">
      <div class="header-subnav-inner site-content-width">
        {{ page.header_subnav }}
      </div>
    </div>
  </header>

  {% if page.breadcrumb %}
    <div class="breadcrumb-wrapper">
      {{ page.breadcrumb }}
    </div>
  {% endif %}

  {% if page.highlighted %}
    <div class="highlighted">
      {{ page.highlighted }}
    </div>
  {% endif %}

  <main class="main-content site-content-width" role="main">
    {% if page.sidebar_first %}
      <aside class="sidebar sidebar-first" role="complementary">
        {{ page.sidebar_first }}
      </aside>
    {% endif %}

    <div class="content-wrapper">
      {% if not is_front and page_title and node_type != 'article' %}
        <h1 class="page-title">{{ page_title }}</h1>
      {% endif %}
      {{ page.content }}
    </div>

    {% if page.sidebar_second %}
      <aside class="sidebar sidebar-second" role="complementary">
        {{ page.sidebar_second }}
      </aside>
    {% endif %}
  </main>

  <footer class="site-footer" role="contentinfo">
    {% if page.footer_first or page.footer_second or page.footer_third %}
      <div class="footer-content">
        {% if page.footer_first %}
          <div class="footer-column footer-first">
            {{ page.footer_first }}
          </div>
        {% endif %}
        {% if page.footer_second %}
          <div class="footer-column footer-second">
            {{ page.footer_second }}
          </div>
        {% endif %}
        {% if page.footer_third %}
          <div class="footer-column footer-third">
            {{ page.footer_third }}
          </div>
        {% endif %}
      </div>
    {% endif %}
    {% if page.footer %}
      <div class="footer-bottom">
        {{ page.footer }}
      </div>
    {% endif %}
  </footer>
</div>

