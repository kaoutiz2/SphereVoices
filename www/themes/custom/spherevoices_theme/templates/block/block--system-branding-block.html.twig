{#
/**
 * @file
 * Bloc branding : liens contextuels (crayon) dans la zone logo, pas en bout de barre.
 *
 * title_suffix (contextual) est rendu à l’intérieur de .site-logo-straddle pour que le
 * survol et le positionnement correspondent au logo.
 */
#}
<div{{ attributes.addClass('site-branding') }}>
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes }}>{{ label }}</h2>
  {% endif %}
  {% if site_logo %}
  <div class="site-logo-straddle">
    {{ title_suffix }}
    <a href="{{ path('<front>') }}" rel="home" class="site-branding__logo">
      <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" fetchpriority="high" />
    </a>
  </div>
  {% endif %}
</div>
