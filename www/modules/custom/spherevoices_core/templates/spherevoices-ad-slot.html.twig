{#
/**
 * @file
 * Single advertising slot (image, Google AdSense, or test placeholder).
 */
#}
{% if mode == 'adsense' %}
  <div class="ad-slot__inner ad-slot__inner--{{ placement }} ad-slot__inner--adsense">
    {% if ad_client and ad_slot %}
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="{{ ad_client }}"
           data-ad-slot="{{ ad_slot }}"
           data-ad-format="{{ ad_format|default('auto') }}"
           data-full-width-responsive="true"></ins>
    {% endif %}
    <div class="ad-slot__placeholder">
      <span class="ad-slot__placeholder-label">{{ 'Publicité'|t }}</span>
      {% if placeholder_message %}
        <span class="ad-slot__placeholder-hint">{{ placeholder_message }}</span>
      {% endif %}
      {% if ad_client %}
        <span class="ad-slot__placeholder-meta">{{ ad_client }}{% if ad_slot %} · slot {{ ad_slot }}{% endif %}</span>
      {% endif %}
    </div>
  </div>
{% elseif mode == 'placeholder' %}
  <div class="ad-slot__inner ad-slot__inner--{{ placement }} ad-slot__inner--placeholder{% if preview_only %} ad-slot__inner--preview{% endif %}">
    <div class="ad-slot__placeholder">
      <span class="ad-slot__placeholder-label">{{ 'Publicité'|t }}</span>
      {% if placeholder_message %}
        <span class="ad-slot__placeholder-hint">{{ placeholder_message }}</span>
      {% endif %}
      {% if ad_client %}
        <span class="ad-slot__placeholder-meta">{{ ad_client }}{% if ad_slot %} · slot {{ ad_slot }}{% endif %}</span>
      {% endif %}
    </div>
  </div>
{% elseif image_url %}
  <div class="ad-slot__inner ad-slot__inner--{{ placement }}">
    {% if url %}
      <a href="{{ url }}" class="ad-slot__link" target="_blank" rel="noopener noreferrer sponsored">
        <img src="{{ image_url }}" alt="{{ alt }}" class="ad-slot__image" loading="lazy" decoding="async" />
      </a>
    {% else %}
      <img src="{{ image_url }}" alt="{{ alt }}" class="ad-slot__image" loading="lazy" decoding="async" />
    {% endif %}
  </div>
{% endif %}
